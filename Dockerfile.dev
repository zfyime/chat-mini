FROM node:20-alpine

WORKDIR /usr/src

RUN npm install -g pnpm@7

# 只拷依赖描述文件，源码通过 volume 挂载，最大化 layer 缓存
COPY package.json pnpm-lock.yaml .npmrc ./
RUN pnpm install --frozen-lockfile

ENV HOST=0.0.0.0 \
    PORT=3000 \
    NODE_ENV=development

EXPOSE 3000

CMD ["pnpm", "run", "dev", "--host", "0.0.0.0"]
