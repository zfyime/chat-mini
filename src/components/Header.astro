---
import Logo from './Logo.astro'
import ThemeSwitch from './ThemeSwitch.astro'
import ModelSelector from './ModelSelector'
---

<header id="page-header" class="sticky top-0 z-30 border-b border-transparent overflow-x-clip">
  <!-- 动态背景层：在吸顶时通过脚本显示，并利用负边距实现全屏遮罩 -->
  <div id="header-bg" class="absolute inset-0 bg-[var(--c-bg)]/80 backdrop-blur-md opacity-0 transition-opacity duration-300"></div>

  <div class="relative max-w-[85ch] mx-auto px-0" id="header-container">
    <div class="fb items-center py-4" id="header-top">
      <div class="fi gap-2">
        <div id="logo-container" class="cursor-pointer transition-transform active:scale-95 hover:opacity-80" title="历史对话">
          <Logo />
        </div>
        <!-- 紧凑版标题：仅在滚动后显示 -->
        <div id="header-title-compact" class="fi opacity-0 -translate-x-2 pointer-events-none transition-all duration-400 cubic-bezier([0.4,0,0.2,1])">
          <span class="text-xl font-extrabold mr-1">Chat</span>
          <span class="text-xl font-extrabold bg-clip-text text-transparent bg-gradient-to-r from-sky-400 to-emerald-600">Mini</span>
        </div>
      </div>
      <div class="fi gap-1">
        <ModelSelector client:load />
        <ThemeSwitch />
      </div>
    </div>

    <!-- 默认大标题区域：滚动后高度塌陷并淡出 -->
    <div id="header-info" class="pb-4 transition-all duration-400 cubic-bezier([0.4,0,0.2,1]) origin-top-left">
      <div class="fi mt-2">
        <span class="gpt-title">Chat</span>
        <span class="gpt-subtitle">Mini</span>
      </div>
      <p mt-1 op-60 class="header-desc text-sm">一个简单的智能聊天机器人。</p>
    </div>
  </div>
</header>

<style>
  /* 滚动状态下的细微边界，使用极低透明度消除黑色细条感 */
  #page-header.is-scrolled {
    @apply border-b-slate/5;
  }

  /* 使得背景在吸顶时全屏，并适配磨砂质感 */
  #page-header.is-scrolled #header-bg {
    @apply opacity-100 backdrop-blur-xl bg-[var(--c-bg)]/80;
  }

  #page-header.is-scrolled #header-top {
    @apply py-1;
  }

  #page-header.is-scrolled #logo-container {
    transform: scale(0.7);
    transform-origin: left center;
  }

  #page-header.is-scrolled #themeToggle {
    transform: scale(0.85);
    transform-origin: right center;
  }

  #page-header.is-scrolled #header-title-compact {
    @apply opacity-100 translate-x-0 pointer-events-auto;
    margin-left: -8px; /* Adjust for logo scale */
  }

  #page-header.is-scrolled #header-info {
    @apply opacity-0 pointer-events-none;
    transform: scale(0.9) translateY(-10px);
    position: absolute;
    left: 0;
    right: 0;
    top: 100%;
  }

  /* 瞬时切换：临时禁用过渡（仅在同帧内使用） */
  #page-header.no-transition,
  #page-header.no-transition * {
    transition-duration: 0s !important;
  }
</style>

<script>
  const header = document.getElementById('page-header')
  const logoContainer = document.getElementById('logo-container')

  let isScrolled = false
  let ticking = false
  let isStreamingLocked = false

  // 无动画地添加 is-scrolled（同帧内完成，不产生过渡）
  const collapseInstant = () => {
    header?.classList.add('no-transition')
    header?.classList.add('is-scrolled')
    isScrolled = true
    void header?.offsetHeight // 强制回流，让 0s 过渡立即生效
    header?.classList.remove('no-transition')
  }

  // 流式输出期间锁定 header，只阻止从收缩恢复展开
  window.addEventListener('streaming-state-change', (e: CustomEvent) => {
    if (e.detail.streaming) {
      isStreamingLocked = true
      // 如果已经滚动过阈值，立即收缩（单步完成，无动画）
      if (window.scrollY > 100 && !isScrolled) {
        collapseInstant()
      }
    } else {
      isStreamingLocked = false
      handleScroll() // 恢复正常逻辑
    }
  })

  const handleScroll = () => {
    if (!ticking) {
      window.requestAnimationFrame(() => {
        const scrollY = window.scrollY

        // 引入迟滞 (Hysteresis) 机制：
        // 1. 向下滚动超过 100px 激活收缩状态
        // 2. 向上滚动回到 20px 以下才恢复原始状态
        // 这 80px 的缓冲区可以有效防止临界点处的反复横跳
        if (scrollY > 100) {
          if (!isScrolled) {
            // 流式期间无动画收缩，避免和滚动产生"两步"感
            if (isStreamingLocked) {
              collapseInstant()
            } else {
              header?.classList.add('is-scrolled')
              isScrolled = true
            }
          }
        } else if (scrollY < 20) {
          // 流式输出期间不允许恢复展开状态，防止高频抖动
          if (isScrolled && !isStreamingLocked) {
            header?.classList.remove('is-scrolled')
            isScrolled = false
          }
        }

        ticking = false
      })
      ticking = true
    }
  }

  window.addEventListener('scroll', handleScroll, { passive: true })
  handleScroll() // 初始化检查

  logoContainer?.addEventListener('click', () => {
    window.dispatchEvent(new CustomEvent('toggle-history'))
  })
</script>
